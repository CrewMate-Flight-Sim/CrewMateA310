        },
        {
          "when": { "responses": ["fifteen"] },
          "checks": [
            { "type": "simvar", "var": "(A:FLAPS HANDLE INDEX, number)", "expected": 2 },
            { "type": "store", "store": "takeoff.flaps", "equals": "2" }
          ]
        },
        {
          "when": { "responses": ["twenty"] },
          "checks": [
            { "type": "simvar", "var": "(A:FLAPS HANDLE INDEX, number)", "expected": 3 },
            { "type": "store", "store": "takeoff.flaps", "equals": "3" }
          ]
        },
        {
          "when": { "responses": ["set and checked"] },
          "checks": [
            {
              "type": "any",
              "groups": [
                [
                  { "type": "simvar", "var": "(A:FLAPS HANDLE INDEX, number)", "expected": 1 },
                  { "type": "store", "store": "takeoff.flaps", "equals": "1" }
                ],
                [
                  { "type": "simvar", "var": "(A:FLAPS HANDLE INDEX, number)", "expected": 2 },
                  { "type": "store", "store": "takeoff.flaps", "equals": "2" }
                ],
                [
                  { "type": "simvar", "var": "(A:FLAPS HANDLE INDEX, number)", "expected": 3 },
                  { "type": "store", "store": "takeoff.flaps", "equals": "3" }
                ]
              ]
            }
          ]
        }
      ]
    },
    {
      "challenge": "ecam_stat.ogg",
      "response": ["checked", "set and checked"],
      "label": "ECAM status"
    },
    {
