                  { "type": "simvar", "var": "(L:A310_ENG2_ANTI_ICE)", "expected": 0 },
                  { "type": "simvar", "var": "(L:A310_WING_ANTI_ICE)", "expected": 0 }
                ],
                [
                  { "type": "store", "store": "takeoff.antiIce", "equals": "oneng" },
                  { "type": "simvar", "var": "(L:A310_ENG1_ANTI_ICE)", "expected": 1 },
                  { "type": "simvar", "var": "(L:A310_ENG2_ANTI_ICE)", "expected": 1 },
                  { "type": "simvar", "var": "(L:A310_WING_ANTI_ICE)", "expected": 0 }
                ],
                [
                  { "type": "store", "store": "takeoff.antiIce", "equals": "onengwing" },
                  { "type": "simvar", "var": "(L:A310_ENG1_ANTI_ICE)", "expected": 1 },
                  { "type": "simvar", "var": "(L:A310_ENG2_ANTI_ICE)", "expected": 1 },
                  { "type": "simvar", "var": "(L:A310_WING_ANTI_ICE)", "expected": 1 }
                ]
              ]
            }
          ]
