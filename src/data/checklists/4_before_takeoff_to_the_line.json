{
  "id": "before_takeoff_to_the_line",
  "name": "Before takeoff checklist to the line",
  "items": [
    {
      "challenge": "flight_controls.ogg",
      "response": ["checked", "set and checked"],
      "label": "Flight Controls",
      "copilot_response": "checked.ogg"
    },
    {
      "challenge": "briefing.ogg",
      "response": ["confirmed", "set and checked"],
      "label": "Briefing"
    },
    {
      "challenge": "slats_flaps.ogg",
      "response": ["fifteen zero", "fifteen", "twenty", "set and checked"],
      "label": "Slats and flaps",
      "incorrect": "are_you_sure.ogg",
      "validations": [
        {
          "when": { "responses": ["fifteen zero"] },
          "checks": [
            { "type": "simvar", "var": "(A:FLAPS HANDLE INDEX, number)", "expected": 1 },
            { "type": "store", "store": "takeoff.flaps", "equals": "1" }
          ],
          "copilot_response": "15_0.ogg"
        },
        {
          "when": { "responses": ["fifteen"] },
          "checks": [
            { "type": "simvar", "var": "(A:FLAPS HANDLE INDEX, number)", "expected": 2 },
            { "type": "store", "store": "takeoff.flaps", "equals": "2" }
          ],
          "copilot_response": "15.ogg"
        },
        {
          "when": { "responses": ["twenty"] },
          "checks": [
            { "type": "simvar", "var": "(A:FLAPS HANDLE INDEX, number)", "expected": 3 },
            { "type": "store", "store": "takeoff.flaps", "equals": "3" }
          ],
          "copilot_response": "20.ogg"
        },
        {
          "when": { "responses": ["set and checked"] },
          "checks": [
            {
              "type": "any",
              "groups": [
                [
                  { "type": "simvar", "var": "(A:FLAPS HANDLE INDEX, number)", "expected": 1 },
                  { "type": "store", "store": "takeoff.flaps", "equals": "1" }
                ],
                [
                  { "type": "simvar", "var": "(A:FLAPS HANDLE INDEX, number)", "expected": 2 },
                  { "type": "store", "store": "takeoff.flaps", "equals": "2" }
                ],
                [
                  { "type": "simvar", "var": "(A:FLAPS HANDLE INDEX, number)", "expected": 3 },
                  { "type": "store", "store": "takeoff.flaps", "equals": "3" }
                ]
              ]
            }
          ]
        }
      ]
    },
    {
      "challenge": "performance_fmas.ogg",
      "response": ["check and read", "set and checked"],
      "label": "Performance and FMAs"
    },
    {
      "challenge": "takeoff_config.ogg",
      "response": ["checked", "set and checked"],
      "label": "Takeoff Config"
    },
    {
      "challenge": "transponder.ogg",
      "response": ["set", "set and checked"],
      "label": "Transponder"
    }
  ],
  "completion": "before_takeoff_completed_to_the_line.ogg"
}
